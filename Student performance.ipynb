      "source": [
        "#Student Performance Dashboard\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "students=['A','B','C','D','E']\n",
        "marks=[78,90,65,88,80]\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "\n",
        "plt.bar(students,marks)\n",
        "\n",
        "plt.title(\"Student Performance\")\n",
        "\n",
        "plt.xlabel(\"Students\")\n",
        "plt.ylabel(\"Marks\")\n",
        "\n",
        "plt.show()"
      ],
